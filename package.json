      "postinstall": "prisma generate"
    },
    "dependencies": {
      "@prisma/client": "^5.14.0",
      "next": "^14.2.0",
      "react": "^18.3.0",
      "react-dom": "^18.3.0",
      "zod": "^3.23.0"
    },
    "devDependencies": {
      "@types/node": "^20.0.0",
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0",
      "prisma": "^5.14.0",
      "ts-node": "^10.9.0",
      "typescript": "^5.0.0"
    },
    "prisma": {
      "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
    }
  }