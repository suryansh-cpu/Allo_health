{
    "name": "allo-platform",
    "version": "1.0.0",
    "private": true,
    "scripts": {
      "dev": "next dev",
      "build": "next build",
      "start": "next start",
      "lint": "next lint",
      "db:generate": "prisma generate",
      "db:migrate": "prisma migrate deploy",
      "db:push": "prisma db push",
